# Application
APP_NAME=Chatbot Framework
APP_VERSION=0.1.0
DEBUG=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database
DATABASE_URL=sqlite:///./chatbot.db

# LLM Configuration
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=1.0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
